DATABASE_URL=sqlite:///./hk_admin.db
SECRET_KEY=your-secret-key-change-in-production-minimum-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=10080
APP_NAME=HK Admin System

# ── AI 服务（收据智能识别）──────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# 默认免费模型，可改为付费模型（更高稳定性）
OPENROUTER_MODEL_FREE=google/gemini-2.0-flash-lite:free
OPENROUTER_MODEL_PAID=google/gemini-2.0-flash-001

# ── 收据文件夹（相对于 backend/ 目录）──────────────────────────
RECEIPTS_INBOX_PATH=./receipts_inbox
RECEIPTS_ARCHIVE_PATH=./receipts_archive
RECEIPTS_ERROR_PATH=./receipts_error

# ── 公司配置（inbox 扫描时须指定默认公司）──────────────────────
DEFAULT_COMPANY_ID=your-company-uuid-here

# ── 性能配置 ─────────────────────────────────────────────────────
INBOX_SCAN_CONCURRENCY=3
